{
  "name": "@cafe-ali/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Cafe Ali backend — see docs/00-overview.md. Phase 1 in progress: Fastify HTTP server + JWT auth + orders domain (localStorage parity being ported route-by-route).",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/src/server.js",
    "build": "tsc -p tsconfig.json",
    "service:start": "pm2 start ecosystem.config.cjs",
    "service:stop": "pm2 stop ecosystem.config.cjs",
    "service:restart": "pm2 restart ecosystem.config.cjs",
    "service:logs": "pm2 logs cafe-ali-backend",
    "service:status": "pm2 status",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.3.0",
    "@fastify/jwt": "^10.2.0",
    "@fastify/sensible": "^6.0.4",
    "@prisma/client": "^6.3.1",
    "fastify": "^5.2.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.10",
    "pm2": "^7.0.3",
    "prisma": "^6.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  }
}
