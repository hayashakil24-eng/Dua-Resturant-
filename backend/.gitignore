node_modules/
dist/
# SQLite dev database + Prisma journal files — local only, never committed.
prisma/dev.db
prisma/dev.db-journal

# Generated by scripts/generate-postgres-schema.mjs from the canonical
# prisma/schema.prisma — never hand-edited, so never committed. The
# migrations it's derived alongside (prisma/postgres/migrations/) ARE
# committed, same as the SQLite side.
prisma/postgres/schema.prisma
# Local secrets. .env holds a dev-only JWT secret + DATABASE_URL; keep it out
# of version control so a real secret is never committed by accident.
.env
