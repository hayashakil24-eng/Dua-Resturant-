.DS_Store
Thumbs.db
desktop.ini

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# Local tooling state (not shared across machines/team members)
*.local
.vite
.claude/scheduled_tasks.lock
