# Dependencies
node_modules

# Build outputs (frontend/dist, frontend/dist-electron, frontend/release,
# control-panel/release — no leading slash so these match at any depth,
# including inside frontend/ and control-panel/). `release*`, not just
# `release`, so one-off alternate output dirs also get caught — e.g.
# `release2` (used when electron-builder's usual `release/` was locked by a
# running/AV-scanned .exe and a build had to go to a fresh dir instead), and
# installer/'s combined-suite output (release-suite/, hundreds of MB). Every
# one of these is a rebuildable binary artifact, never source.
dist
dist-ssr
dist-electron
release*

# Env / secrets — none exist yet, but the future backend will need these
.env
.env.local
.env.*.local
creds.md

# Editor / IDE
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# Local tooling state (not shared across machines/team members)
*.local
.vite
.claude/scheduled_tasks.lock

# Backend local SQLite database (dev data, not shared — schema lives in
# backend/prisma/schema.prisma, migrations are tracked, the .db file isn't).
# -wal/-shm are SQLite's WAL-mode side files, same rule applies.
*.db
*.db-journal
*.db-wal
*.db-shm
